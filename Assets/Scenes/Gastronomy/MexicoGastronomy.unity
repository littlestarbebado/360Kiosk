          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: "<b>Origem:</b> Civiliza\xE7\xF5es pr\xE9-colombianas
            do M\xE9xico. <b>Inspira\xE7\xE3o:</b> Prato ritual\xEDstico usado em
            cerim\xF3nias antigas. <b>O Nome:</b> Vem do n\xE1uatle \u201Cpozolli\u201D,
            significando espumoso. <b>Composi\xE7\xE3o:</b> Sopa de milho hominy
            com carne (porco ou frango), especiarias e guarni\xE7\xF5es. <b>A Alma:</b>
            Calor profundo e reconfortante com camadas de sabor tradicionais. <b>Tradi\xE7\xE3o:</b>
            Servido em festas nacionais, especialmente no Dia da Independ\xEAncia."
          m_BoolArgument: 0
        m_CallState: 2
